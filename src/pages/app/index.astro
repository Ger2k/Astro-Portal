---
export const prerender = true;
import AppLayout from "@/layouts/AppLayout.astro";
import { AppPrivateView } from "@/domains/auth/components/AppPrivateView";
---

<AppLayout title="App | Portal Games Tracker" description="Zona privada con autenticación Google">
  <section class="space-y-6">
    <header class="surface-card p-6">
      <h1 class="text-2xl font-semibold">Tu biblioteca de juegos completados</h1>
      <p class="mt-2 text-sm text-muted-foreground">
        Gestiona tus juegos, registra nuevas partidas y mantén tu historial actualizado.
      </p>
    </header>

    <AppPrivateView client:load />
  </section>
</AppLayout>

