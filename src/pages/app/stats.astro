---
export const prerender = false;
import AppLayout from "@/layouts/AppLayout.astro";
import { AppHeaderSessionBar } from "@/domains/auth/components/AppHeaderSessionBar";
import { AppStatsView } from "@/domains/games/components/AppStatsView";
---

<AppLayout title="Estadísticas | Portal" description="Insights y métricas de tu biblioteca de juegos">
  <AppHeaderSessionBar slot="header-extra" client:load />

  <section class="space-y-6">
    <header class="surface-card p-4 sm:p-6">
      <h1 class="text-xl font-semibold sm:text-2xl">Estadísticas de tu biblioteca</h1>
      <p class="mt-2 text-sm text-muted-foreground">
        Analiza tus hábitos de juego con una vista dedicada y consulta tus métricas cuando quieras.
      </p>
    </header>

    <AppStatsView client:load />
  </section>
</AppLayout>
