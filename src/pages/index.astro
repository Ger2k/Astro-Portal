---
export const prerender = true;
import AppLayout from '@/layouts/AppLayout.astro';
import { HomeAuthCard } from '@/domains/auth/components/HomeAuthCard';
---

<AppLayout title="Portal Games Tracker" description="Gestión personal de juegos completados">
  <section class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
    <h1 class="text-2xl font-semibold text-foreground">Portal Games Tracker</h1>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">
      Guarda tus juegos terminados, consulta tu historial y organiza tu colección personal en un solo lugar.
    </p>

    <div class="mt-6">
      <HomeAuthCard client:load />
    </div>
  </section>
</AppLayout>

