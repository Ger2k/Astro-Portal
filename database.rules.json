{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "games": {
          "$gameId": {
            ".validate": "newData.hasChildren(['title', 'platform'])"
          }
        },
        "achievements": {
          "$achievementId": {
            ".validate": "newData.hasChildren(['id', 'key', 'title', 'description', 'rarity', 'unlockedAt', 'placeholderIcon', 'progress', 'progressMax'])",
            "unlockedAt": {
              ".write": "!data.exists()"
            }
          }
        }
      }
    }
  }
}
