{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "games": {
          "$gameId": {
            ".validate": "newData.hasChildren(['title', 'platform'])"
          }
        }
      }
    }
  }
}
